{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./*"],
      "@english-variant/shared": ["../../packages/shared/src/index.ts"],
      "@english-variant/shared/*": ["../../packages/shared/src/*"],
      "@english-variant/content": ["../../packages/content/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
